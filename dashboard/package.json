{
  "name": "dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "dev": "node dev.js",
    "dev:server": "ts-node server/index.ts",
    "dev:client": "cd client && npm run dev"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
